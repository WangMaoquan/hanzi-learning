# ==================== 应用配置 ====================
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ==================== 数据库 ====================
DATABASE_URL="postgresql://user:password@host:port/db_name"

# ==================== 缓存配置 ====================
CACHE_TTL=60000

# ==================== 限流配置 ====================
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=200

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_ENABLE_DETAILED=true
LOG_REQUEST_BODY=true
LOG_RESPONSE_BODY=true
LOG_MAX_BODY_LENGTH=500
LOG_QUERY_PARAMS=true
LOG_ROUTE_PARAMS=true
LOG_USER_INFO=true
LOG_IP_ADDRESS=true
LOG_USER_AGENT=true
SLOW_REQUEST_THRESHOLD=500
