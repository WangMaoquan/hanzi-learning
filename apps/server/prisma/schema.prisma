generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id          String   @id @default(uuid())
  word        String   @unique
  pinyin     String?  // 主拼音，多音字用逗号分隔，如 "ai,shui"
  pinyins    String?  // 多音字完整拼音列表，如 "ai,shui"
  radical    String?
  strokes    Int?     // 主笔画数
  strokeMap  Json?    // 多音字对应的笔画数，如 {"ai": 10, "shui": 12}
  structure  String?
  explanation String?
  words      String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([word])
}

model Idiom {
  id          String   @id @default(uuid())
  word        String   @unique
  pinyin     String?
  derivation  String?
  explanation String?
  example     String?
  synonyms    String[]
  antonyms    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([word])
}

model Poem {
  id            String     @id @default(uuid())
  title         String
  author        String
  content       String     // 完整内容，字符串格式，用换行符分隔
  pinyin        String?    // 全文拼音
  difficulty    Int?       // 难度 1-5
  tags          String[]   // 标签，如 ['唐诗', '李白']
  dynasty       String     // 英文: tang, song, yuan, ming, qing
  type          String?    // 词牌名（宋词）
  verses        String[]   // 每句诗的数组
  versePinyins  Json?     // 每句每个字的拼音
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([title])
  @@index([author])
  @@index([dynasty])
}
