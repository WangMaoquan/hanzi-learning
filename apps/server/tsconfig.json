{
  "extends": "@hanzi-learning/tsconfig/base.json",
  "include": ["src/**/*", "scripts/**/*"],
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "baseUrl": ".",
    "noEmit": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@hanzi-learning/types/vo": ["../../packages/types/src/vo/index.ts"],
      "@hanzi-learning/types/vo/*": ["../../packages/types/src/vo/*"]
    }
  }
}
